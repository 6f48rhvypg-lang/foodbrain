# Required for live Grocy access
FOODBRAIN_GROCY_BASE_URL=http://grocy.local
FOODBRAIN_GROCY_API_KEY=replace-me

# Optional: publish run summaries to a Home Assistant webhook URL
FOODBRAIN_HOME_ASSISTANT_WEBHOOK_URL=

# Optional scoring controls
FOODBRAIN_EXPIRY_WINDOW_DAYS=7
FOODBRAIN_TOP_INGREDIENT_LIMIT=8
FOODBRAIN_TOP_RECIPE_LIMIT=5

# Optional FlavorGraph pairing controls (used with --pairings-json)
FOODBRAIN_TOP_PAIRING_LIMIT=5
FOODBRAIN_PAIRING_PARTNER_LIMIT=4

# Optional: voice/photo intake ("talk into your phone at the fridge").
# Set an OpenRouter key to enable the Add-by-voice flow. The model is any
# OpenRouter slug (a text model is fine for voice; use a vision model later
# for the photo path).
FOODBRAIN_OPENROUTER_API_KEY=
FOODBRAIN_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
FOODBRAIN_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: defaults when intake has to create a brand-new Grocy product.
# Names must match an existing Grocy location / quantity unit; otherwise the
# first available one is used.
FOODBRAIN_INTAKE_DEFAULT_LOCATION=
FOODBRAIN_INTAKE_DEFAULT_UNIT=

# Optional: recipe inspiration ("Ideen holen"). Reuses the OpenRouter key above.
# The idea/headline step is the creative bottleneck -> default strong model;
# the recipe step is mechanical -> default cheap model. Both are overridable
# per request from the SPA Settings panel (stored in localStorage).
FOODBRAIN_IDEA_MODEL=google/gemini-3.1-pro-preview
FOODBRAIN_RECIPE_MODEL=google/gemini-3.1-flash-lite
# How fresh-vs-personalized ideas lean: 0 = only fresh, 1 = fully personalized.
FOODBRAIN_RECIPE_EXPLORE_BALANCE=0.7
# Persistent, writable dir for the learning store (cookmemory.json) + recipe
# book. In the CT 105 container this must survive restarts/redeploys.
FOODBRAIN_DATA_DIR=data
