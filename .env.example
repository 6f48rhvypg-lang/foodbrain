# Required for live Grocy access
FOODBRAIN_GROCY_BASE_URL=http://grocy.local
FOODBRAIN_GROCY_API_KEY=replace-me

# Optional: publish run summaries to a Home Assistant webhook URL
FOODBRAIN_HOME_ASSISTANT_WEBHOOK_URL=

# Optional scoring controls
FOODBRAIN_EXPIRY_WINDOW_DAYS=7
FOODBRAIN_TOP_INGREDIENT_LIMIT=8
FOODBRAIN_TOP_RECIPE_LIMIT=5

# Optional FlavorGraph pairing controls (used with --pairings-json)
FOODBRAIN_TOP_PAIRING_LIMIT=5
FOODBRAIN_PAIRING_PARTNER_LIMIT=4
